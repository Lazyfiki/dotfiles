# My Hotkeys

Print
	maim --select | tee ~/pix/ss/$(date +%s).jpg | xclip -sel c -t image/jpg

super + Print
	maim | tee ~/pix/ss/$(date +%s).jpg | xclip -sel c -t image/jpg

super + alt + {Up,Down,0}
	amixer set Master {5%+,5%-,toggle}; kill -34 $(cat ~/.cache/pidofbar)

super + alt + {Right,Left}
	brightnessctl s {+2%,2%-}

super + Escape
	system_action
